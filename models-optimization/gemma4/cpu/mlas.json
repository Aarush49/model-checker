{
    "input_model": {
        "type": "HfModel",
        "model_path": "google/gemma-4-E4B-it",
        "task": "text-generation"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "cpu",
                    "execution_providers": [
                        "CPUExecutionProvider"
                    ]
                }
            ]
        }
    },
    "engine": {
        "target": "local_system"
    },
    "passes": {
        "builder": {
            "type": "ModelBuilder",
            "precision": "int4"
        }
    },
    "cache_dir": "cache",
    "clean_cache": true,
    "output_dir": "models/gemma4/cpu/mlas"
}